    "Choose a recipient.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите получателя."
          }
        }
      }
    },
    "Classic OpenPGP (asymmetric): manage your keypairs, share a public key, encrypt to a contact's public key, decrypt with your private key.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классический OpenPGP (асимметричный): управляйте своими ключами, делитесь публичным ключом, шифруйте на публичный ключ контакта и расшифровывайте своим приватным."
          }
        }
      }
    },
    "Classic OpenPGP (asymmetric): share your public key, encrypt to a contact's public key, decrypt with your private key. Different from the shared-password mode.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классический OpenPGP (асимметричный): поделитесь публичным ключом, шифруйте на публичный ключ собеседника, расшифровывайте своим приватным ключом. Отличается от режима с общим паролем."
          }
        }
      }
    },
    "Classic asymmetric encryption with signatures, compatible with other PGP tools.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классическое асимметричное шифрование с подписями, совместимое с другими PGP-инструментами."
          }
        }
      }
    },
    "Clear all chats": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистить все чаты"
          }
        }
